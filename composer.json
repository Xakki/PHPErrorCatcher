{
  "name": "xakki/phperrorcatcher",
  "version": "0.8.4",
  "description": "PHP Logger - Monolog/PSR compatible",
  "type": "library",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "license": "GPL-3.0-or-later",
  "authors": [
    {
      "name": "Xakki",
      "email": "git@xakki.ru"
    }
  ],
  "homepage": "https://xakki.github.io/phperrorcatcher/",
  "support": {
    "issues": "https://github.com/xakki/phperrorcatcher/issues"
  },
  "require": {
    "php": "^8.3",
    "ext-mbstring": "*",
    "ext-json": "*",
    "ext-curl": "*",
    "ext-pdo": "*",
    "psr/log": "^3.0",
    "ext-sockets": "*",
    "ext-ctype": "*"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.0",
    "squizlabs/php_codesniffer": "^3.13",
    "opsway/psr12-strict-coding-standard": "^1.1",
    "phpunit/phpunit": "^12.0"
  },
  "autoload": {
    "psr-4": {
        "Xakki\\PhpErrorCatcher\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
        "Xakki\\PhpErrorCatcher\\Tests\\": "tests/"
    }
  },
  "config": {
    "preferred-install": "dist",
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "scripts": {
    "phpstan": "phpstan analyse --memory-limit 1G",
    "cs-check": "phpcs",
    "cs-fix": "phpcbf",
    "phpunit": "phpunit"
  }
}
