parameters:
	ignoreErrors:
		-
			message: "#^Access to an undefined property Xakki\\\\PhpErrorCatcher\\\\PhpErrorCatcher\\:\\:\\$globalTag\\.$#"
			count: 2
			path: src/PhpErrorCatcher.php

		-
			message: "#^Call to an undefined method Xakki\\\\PhpErrorCatcher\\\\PhpErrorCatcher\\:\\:getCountByLevelAndLess\\(\\)\\.$#"
			count: 1
			path: src/PhpErrorCatcher.php

		-
			message: "#^Cannot call method format\\(\\) on DateTime\\|false\\.$#"
			count: 1
			path: src/PhpErrorCatcher.php

		-
			message: "#^Offset int on array\\<string, int\\> in isset\\(\\) does not exist\\.$#"
			count: 3
			path: src/PhpErrorCatcher.php

		-
			message: "#^Parameter \\#1 \\$level of method Xakki\\\\PhpErrorCatcher\\\\PhpErrorCatcher\\:\\:createLogData\\(\\) expects int, string given\\.$#"
			count: 1
			path: src/PhpErrorCatcher.php

		-
